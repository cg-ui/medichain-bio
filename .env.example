# MONGODB_URI: Connection string for MongoDB Atlas or local instance.
MONGODB_URI="mongodb://localhost:27017/medichain"

# JWT_SECRET: Secret key for signing JWT tokens.
JWT_SECRET="your_jwt_secret_here"

# Pinata IPFS JWT (server-side only, required for IPFS uploads)
PINATA_JWT="your_pinata_jwt_here"

# Label used in the cloud backup metadata
VITE_CLOUD_PROVIDER="MongoDB Atlas"

# Pinata Dedicated Gateway URL (Optional, for IPFS retrieval)
# Example: https://my-gateway.mypinata.cloud
VITE_PINATA_GATEWAY_URL=""

# GEMINI_API_KEY: Required for AI-generated privacy summaries
# Optional - if not set, cloud backup uses fallback text
#Removed
GEMINI_API_KEY=""

# APP_URL: The URL where this app is hosted (optional)
APP_URL=""

# USE_ARGON2: Set to 'true' to use Argon2 for password hashing (more secure)
# If 'false' or unset, bcryptjs is used as fallback
USE_ARGON2=true
