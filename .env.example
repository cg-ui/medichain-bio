# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="AIzaSyDnTJHBuEaeV_Z2Lz08v9OJ-YYEeKnErz0"

# MONGODB_URI: Connection string for MongoDB Atlas or local instance.
MONGODB_URI="mongodb://localhost:27017/medichain"

# JWT_SECRET: Secret key for signing JWT tokens.
JWT_SECRET="your_jwt_secret_here"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Pinata IPFS JWT
VITE_PINATA_JWT="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..4KolqCth9nnjoBnBEzqJ9enYzIYBXkzsNcvnMKvxCSw"

# Pinata Dedicated Gateway URL (Optional)
# Example: https://my-gateway.mypinata.cloud
VITE_PINATA_GATEWAY_URL=
